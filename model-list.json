  "schema": {
    "reasoning": {
      "description": "Reasoning configuration for a model",
      "properties": {
        "supported": { "type": "boolean", "required": true, "description": "Does this model support reasoning at all?" },
        "toggleable": { "type": "boolean", "description": "Can user toggle reasoning on/off?" },
        "defaultEnabled": { "type": "boolean", "description": "Initial state (if toggleable)" },
        "effort": {
          "type": "object",
          "description": "Optional effort level configuration",
          "properties": {
            "levels": { "type": "array", "items": { "type": "string" } },
            "default": { "type": "string" }
          }
        },
        "alternateModel": { "type": "string", "description": "Optional - route to different model when reasoning enabled" }
      }
    },
    "modelProperties": {
      "id": { "type": "string", "required": true, "description": "OpenRouter model ID" },
      "name": { "type": "string", "required": true, "description": "Display name in UI" },
      "description": { "type": "string", "description": "Short description shown in model picker" },
      "vision": { "type": "boolean", "description": "Supports image/vision input" },
      "tool_use": { "type": "boolean", "description": "Supports tool/function calling. Defaults to true if omitted." },
      "providers": { "type": "array", "items": { "type": "string" }, "description": "Restrict to specific OpenRouter provider(s)" },
      "extra_functions": { "type": "array", "description": "Reserved for future use" },
      "extra_parameters": { "type": "object", "description": "Reserved for future use" }
    }
  },
